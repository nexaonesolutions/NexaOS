################################################################################
#  NEXA OS - PACMAN MIRRORLIST
#  Salvar em: airootfs/etc/pacman.d/mirrorlist
#
#  Gerado para compilação da ISO pelo archiso.
#  Mirrors ordenados por região para menor latência no Brasil.
################################################################################

# --- Brasil ---
Server = https://br.mirror.archlinux-br.org/$repo/os/$arch
Server = https://mirrors.ufpr.br/archlinux/$repo/os/$arch
Server = https://archlinux.c3sl.ufpr.br/$repo/os/$arch

# --- América do Sul (Fallback) ---
Server = https://mirror.ufscar.br/archlinux/$repo/os/$arch

# --- Global CDN (Fallback final) ---
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
